# Supabase — Project Settings → API (Publishable key)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_publishable_ou_anon_aqui

# Opcional — interpretação avançada de comandos de voz (Google AI Studio)
# VITE_GEMINI_API_KEY=sua_chave_gemini_aqui

# Opcional — URLs do portal de sistemas (padrão: produção)
# VITE_WMS_LIGHT_URL=https://doca-livre-wms-light.onrender.com/
# VITE_WMS_PRO_URL=https://doca-livre-wms-pro.onrender.com/
# VITE_WMS_ORIGINAL_URL=https://sistema.docalivre.com.br/login

# SSO: o Plus valida o token chamando o Pro em VITE_WMS_PRO_URL/api/sso/verify
# (não coloque SSO_SECRET no frontend Vite).
# Acesso direto ao Plus em produção redireciona ao portal Pro.
# Escape local: ?stay=1  ou  VITE_ALLOW_DIRECT_ACCESS=1
